# ── StoryGraph environment ──────────────────────────────────
# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored — never commit real keys.

# Provider selection: "bedrock" | "anthropic" | (blank = auto, falls back to mock)
# Auto-detects: Anthropic key → anthropic; else AWS creds → bedrock; else mock.
LLM_PROVIDER=

# Default model (per-story model still wins). claude-haiku-4-5 | claude-opus-4-6 | claude-sonnet-4-6
CLAUDE_MODEL=claude-haiku-4-5

# ── Option A: Anthropic API ─────────────────────────────────
# Direct Anthropic Messages API. Leave blank to skip.
ANTHROPIC_API_KEY=

# ── Option B: Amazon Bedrock ────────────────────────────────
# Routes Claude through Bedrock via the @anthropic-ai/bedrock-sdk.
# Credentials come from the standard AWS chain: an AWS profile locally,
# or (recommended in prod) an IAM role attached to the host — no keys in code.
# AWS_REGION=ap-northeast-2
# AWS_PROFILE=bedrock          # local dev only; on AWS use an instance/task role
