# ── StoryGraph environment ──────────────────────────────────
# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored — never commit real keys.

# Anthropic API key for LIVE Claude Opus 4.6 narration.
# Leave blank to run in DEMO MODE: a mock streamed narrator so the whole
# app is fully playable offline (great for screen recordings).
ANTHROPIC_API_KEY=

# Model id (Anthropic Messages API). Default: claude-opus-4-6
CLAUDE_MODEL=claude-opus-4-6

# ── Optional: Google Vertex AI ──────────────────────────────
# You can route Claude through Vertex AI using the public
# `@anthropic-ai/vertex-sdk` (AnthropicVertex) with a service-account JSON —
# a one-client swap in src/lib/llm.ts. Then set:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCP_PROJECT=
# GCP_LOCATION=us-east5
